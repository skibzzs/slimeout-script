                                    task.wait(0.1)
                                    owned = upgradesSrc() or {}
                                end
                            end
                        end
                    end)
                    if boughtSomething then
                        task.wait(0.5)
                    else
                        task.wait(2.5)
                    end
                end
                pcall(destroyScope)
            end)
        end
    end,
})

