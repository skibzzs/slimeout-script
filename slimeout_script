local function applyAntiAFK(state)
    pcall(function()
        if getconnections then
            for _, connection in pairs(getconnections(LocalPlayer.Idled)) do
                if state then
                    connection:Disable()
                else
                    connection:Enable()
                end
            end
        end
    end)

    pcall(function()
        local AutoRejoinModule = require(ReplicatedStorage.Source.Features.AutoRejoin.AutoRejoinServiceClient)
        if type(AutoRejoinModule) == "table" then
            if state then
                if not getgenv().OriginalAutoRejoin then
                    getgenv().OriginalAutoRejoin = {}
                    for k, v in pairs(AutoRejoinModule) do
                        if type(v) == "function" then
                            getgenv().OriginalAutoRejoin[k] = v
                            AutoRejoinModule[k] = function() return end
                        end
                    end
                end
            else
                if getgenv().OriginalAutoRejoin then
                    for k, v in pairs(getgenv().OriginalAutoRejoin) do
                        AutoRejoinModule[k] = v
                    end
                    getgenv().OriginalAutoRejoin = nil
                end
            end
        end
    end)
end

