local CraftingRecipesModule = require(ReplicatedStorage:WaitForChild("Source"):WaitForChild("Features"):WaitForChild("Crafting"):WaitForChild("Recipes"))

local function getRawRecipes()
    if type(CraftingRecipesModule) == "table" and type(CraftingRecipesModule.getRecipes) == "function" then
        return CraftingRecipesModule.getRecipes()
    end
    local recipes = {}
    for key, value in pairs(CraftingRecipesModule) do
        if type(value) == "table" and value.id then
            table.insert(recipes, value)
        end
    end
    return recipes
end

local function buildRecipeCache()
    local displayToRecipe = {}
    local options = {}
    for _, recipe in ipairs(getRawRecipes()) do
        if not recipe.hidden then
            local displayName = recipe.outputId or recipe.id
            local ingredients = {}
            for _, input in ipairs(recipe.inputs or {}) do
                table.insert(ingredients, "-" .. input.id)
            end
            displayToRecipe[displayName] = {
                id = recipe.id,
                outputId = recipe.outputId,
                ingredients = ingredients,
                layoutOrder = recipe.layoutOrder or math.huge,
                description = recipe.description
            }
            table.insert(options, displayName)
        end
    end
    table.sort(options, function(a, b)
        return (displayToRecipe[a].layoutOrder or math.huge) < (displayToRecipe[b].layoutOrder or math.huge)
    end)
    return options, displayToRecipe
end

