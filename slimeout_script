local function sendStatsWebhook(isInitial, currentCoins, currentGoop, currentRolls, deltaCoins, deltaGoop, deltaRolls, minutesPassed)
    local targetUrl = getgenv().StatWebhookURL ~= "" and getgenv().StatWebhookURL or getgenv().WebhookURL
    if targetUrl == "" then return end

    local unixTime = math.floor(os.time())
    local discordTimestamp = "<t:" .. unixTime .. ":R>"
    local playerStr = getgenv().ShowUsername and ("||" .. LocalPlayer.Name .. "||") or "Hidden"

    local embed = {}
    if isInitial then
        embed = {
            ["title"] = "📊 Stats Tracker Started",
            ["description"] = "Tracker initialized " .. discordTimestamp .. "\n👤 **Player:** " .. playerStr,
            ["color"] = 3447003, -- Blue
            ["fields"] = {
                { ["name"] = "🪙 Initial Coins", ["value"] = formatNumberSuffix(currentCoins), ["inline"] = true },
                { ["name"] = "🧪 Initial Goop", ["value"] = formatNumberSuffix(currentGoop), ["inline"] = true },
                { ["name"] = "🎲 Initial Rolls", ["value"] = formatNumberSuffix(currentRolls), ["inline"] = true },
            },
            ["footer"] = { ["text"] = "Slimeout Tracker • Initializing" }
        }
    else
        local coinsPerMin = deltaCoins / minutesPassed
        local goopPerMin = deltaGoop / minutesPassed
        local rollsPerMin = deltaRolls / minutesPassed
        local coinsPerHour = coinsPerMin * 60
        local goopPerHour = goopPerMin * 60
        local rollsPerHour = rollsPerMin * 60

        embed = {
            ["title"] = "📈 Stats Update",
            ["description"] = "Update sent " .. discordTimestamp .. "\n👤 **Player:** " .. playerStr,
            ["color"] = 5763719, -- Green
            ["fields"] = {
                { ["name"] = "🪙 Coins", ["value"] = formatNumberSuffix(currentCoins), ["inline"] = true },
                { ["name"] = "💰 Earned", ["value"] = (deltaCoins >= 0 and "+" or "") .. formatNumberSuffix(deltaCoins), ["inline"] = true },
                { ["name"] = "⚡ Coins/Hr", ["value"] = formatNumberSuffix(coinsPerHour) .. "/h", ["inline"] = true },

                { ["name"] = "🧪 Goop", ["value"] = formatNumberSuffix(currentGoop), ["inline"] = true },
                { ["name"] = "🦠 Earned", ["value"] = (deltaGoop >= 0 and "+" or "") .. formatNumberSuffix(deltaGoop), ["inline"] = true },
                { ["name"] = "🫧 Goop/Hr", ["value"] = formatNumberSuffix(goopPerHour) .. "/h", ["inline"] = true },

                { ["name"] = "🎲 Rolls", ["value"] = formatNumberSuffix(currentRolls), ["inline"] = true },
                { ["name"] = "🎲 Earned", ["value"] = (deltaRolls >= 0 and "+" or "") .. formatNumberSuffix(deltaRolls), ["inline"] = true },
                { ["name"] = "🎲 Rolls/Hr", ["value"] = formatNumberSuffix(rollsPerHour) .. "/h", ["inline"] = true },
            },
            ["footer"] = { ["text"] = string.format("Slimeout Tracker • Over the last %d minutes", math.floor(minutesPassed)) }
        }
    end

    local data = {
        ["content"] = "", 
        ["embeds"] = {embed}
    }

    table.insert(WebhookQueue, {
        sendFunc = function()
            local reqFunc = (request or http and http.request or syn and syn.request)
            if reqFunc then
                reqFunc({
                    Url = targetUrl,
                    Method = "POST",
                    Headers = {["Content-Type"] = "application/json"},
                    Body = HttpService:JSONEncode(data)
                })
            end
        end
    })
end

local isTrackerRunning = false
local lastCoins = 0
local lastGoop = 0
local lastRolls = 0
local lastTick = 0

local function startTracker()
    if isTrackerRunning then return end
    isTrackerRunning = true
    task.spawn(function()
        task.wait(3) 

        local vide = require(ReplicatedStorage.Packages.Vide)
        local getDataSource = require(ReplicatedStorage.Source.Core.UI.Sources.getDataSource)

        local coinsSrc, goopSrc, statsSrc

        local destroyScope = vide.root(function()
            coinsSrc = getDataSource("coins")
            goopSrc = getDataSource("goop")
            statsSrc = getDataSource("stats")
        end)
        table.insert(getgenv().VideScopes, destroyScope)

        lastCoins = coinsSrc() or 0
        lastGoop = goopSrc() or 0
        local statsTbl = statsSrc()
        lastRolls = safeRead(statsTbl, "rolls", 0)

        lastTick = tick()

        if getgenv().StatTrackerEnabled then
            sendStatsWebhook(true, lastCoins, lastGoop, lastRolls, 0, 0, 0, 0)
        end

        while getgenv().StatTrackerEnabled do
            local targetTime = lastTick + (getgenv().StatTrackerInterval * 60)

            while getgenv().StatTrackerEnabled and tick() < targetTime do
                task.wait(1)
            end

            if not getgenv().StatTrackerEnabled then break end

            local currentCoins = coinsSrc() or 0
            local currentGoop = goopSrc() or 0
            local currStatsTbl = statsSrc()
            local currentRolls = safeRead(currStatsTbl, "rolls", 0)

            local elapsedSecs = tick() - lastTick
            local elapsedMins = elapsedSecs / 60

            local dCoins = currentCoins - lastCoins
            local dGoop = currentGoop - lastGoop
            local dRolls = currentRolls - lastRolls

            if elapsedMins > 0 then
                sendStatsWebhook(false, currentCoins, currentGoop, currentRolls, dCoins, dGoop, dRolls, elapsedMins)
            end

            lastCoins = currentCoins
            lastGoop = currentGoop
            lastRolls = currentRolls
            lastTick = tick()
        end

        pcall(destroyScope)
        isTrackerRunning = false
    end)
end

