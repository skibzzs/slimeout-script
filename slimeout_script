-- Define the Remotes safely
local function findNetworkerRemotes()
    local packages = ReplicatedStorage:WaitForChild("Packages")
    local index = packages:WaitForChild("_Index")

    local networkerPkg = index:FindFirstChild("leifstout_networker@0.3.1")
    if not networkerPkg then
        for _, child in ipairs(index:GetChildren()) do
            if string.match(child.Name, "^leifstout_networker@") then
                networkerPkg = child
                break
            end
        end
    end

    if not networkerPkg then
        warn("Networker package not found, yielding until it exists")
        while not networkerPkg do
            task.wait(1)
            for _, child in ipairs(index:GetChildren()) do
                if string.match(child.Name, "^leifstout_networker@") then
                    networkerPkg = child
                    break
                end
            end
        end
    end

    return networkerPkg:WaitForChild("networker"):WaitForChild("_remotes")
end

