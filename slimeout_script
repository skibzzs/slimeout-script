            task.spawn(function()
                local vide = require(ReplicatedStorage.Packages.Vide)
                local UpgradeTree = require(ReplicatedStorage.Source.Features.Upgrades.UpgradeTree)
                local UpgradeCounterUtils = require(ReplicatedStorage.Source.Features.Upgrades.UpgradeCounterUtils)
                local getDataSource = require(ReplicatedStorage.Source.Core.UI.Sources.getDataSource)

                local upgradesSrc, coinsSrc, goopSrc, rollCurrencySrc

                local destroyScope = vide.root(function()
                    upgradesSrc = getDataSource("upgrades")
                    coinsSrc = getDataSource("coins")
                    goopSrc = getDataSource("goop")
                    rollCurrencySrc = getDataSource("rollCurrency")
                end)
                table.insert(getgenv().VideScopes, destroyScope)

                local function getCurrencyAmt(curr)
                    if curr == "coins" then return coinsSrc() or 0 end
                    if curr == "goop" then return goopSrc() or 0 end
                    if curr == "rollCurrency" then return rollCurrencySrc() or 0 end
                    return 0
                end

                local flatUpgrades = {}
                for k, v in pairs(UpgradeTree) do
                    if type(v) == "table" then
                        if v.cost then
                            v.id = v.id or k
                            table.insert(flatUpgrades, v)
                        else
                            for subK, subV in pairs(v) do
                                if type(subV) == "table" and subV.cost then
                                    subV.id = subV.id or subK
                                    table.insert(flatUpgrades, subV)
                                end
                            end
                        end
                    end
                end

                table.sort(flatUpgrades, function(a, b)
                    return (tonumber(a.cost.amount) or 0) < (tonumber(b.cost.amount) or 0)
                end)

                while getgenv().AutoBuyUpgrades do
                    local boughtSomething = false
                    pcall(function()
                        local owned = upgradesSrc() or {}
                        for _, upg in ipairs(flatUpgrades) do
                            if not getgenv().AutoBuyUpgrades then break end
                            if UpgradeCounterUtils.canPurchase(upg, owned, getCurrencyAmt) then
