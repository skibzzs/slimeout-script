local function parseMultiplier(str)
    str = tostring(str):lower():gsub(",", ""):gsub(" ", "")
    local num = tonumber(str)
    if num then return num end

    local val, suffix = string.match(str, "^([%d%.]+)([a-zA-Z]+)$")
    if not val or not suffix then return 0 end

    val = tonumber(val)
    if not val then return 0 end

    local multipliers = { 
        k = 1e3, m = 1e6, b = 1e9, t = 1e12, 
        qa = 1e15, qi = 1e18, sx = 1e21, sp = 1e24, 
        oc = 1e27, no = 1e30, dc = 1e33, ud = 1e36, 
        dd = 1e39, td = 1e42, qd = 1e45 
    }

    local mult = multipliers[suffix]
    if not mult then
        return val
    end

    return val * mult
end

local function formatNumberSuffix(val)
    if not val then return "0" end
    local absVal = math.abs(val)
    local sign = val < 0 and "-" or ""

    if absVal >= 1e45 then return string.format("%s%.2fQd", sign, absVal / 1e45) end
    if absVal >= 1e42 then return string.format("%s%.2fTd", sign, absVal / 1e42) end
    if absVal >= 1e39 then return string.format("%s%.2fDd", sign, absVal / 1e39) end
    if absVal >= 1e36 then return string.format("%s%.2fUd", sign, absVal / 1e36) end
    if absVal >= 1e33 then return string.format("%s%.2fDc", sign, absVal / 1e33) end
    if absVal >= 1e30 then return string.format("%s%.2fNo", sign, absVal / 1e30) end
    if absVal >= 1e27 then return string.format("%s%.2fOc", sign, absVal / 1e27) end
    if absVal >= 1e24 then return string.format("%s%.2fSp", sign, absVal / 1e24) end
    if absVal >= 1e21 then return string.format("%s%.2fSx", sign, absVal / 1e21) end
    if absVal >= 1e18 then return string.format("%s%.2fQi", sign, absVal / 1e18) end
    if absVal >= 1e15 then return string.format("%s%.2fQa", sign, absVal / 1e15) end
    if absVal >= 1e12 then return string.format("%s%.2fT", sign, absVal / 1e12) end
    if absVal >= 1e9 then return string.format("%s%.2fB", sign, absVal / 1e9) end
    if absVal >= 1e6 then return string.format("%s%.2fM", sign, absVal / 1e6) end
    if absVal >= 1e3 then return string.format("%s%.2fK", sign, absVal / 1e3) end
    return sign .. tostring(math.floor(absVal))
end

local function formatOdds(oddsValue)
    if not oddsValue or oddsValue <= 0 then return "Unknown" end
    local chance = 1 / oddsValue
    return "1/" .. formatNumberSuffix(chance):gsub("-", "")
end

local function getRobloxImage(assetIdStr)
    if not assetIdStr then return nil end
    local id = string.match(tostring(assetIdStr), "%d+")
    if not id then return nil end
    return "https://biggamesapi.io/image/" .. id
end

local function getTargetZone()
    local bestZone = ZonesServiceClient:getMaxZone()
    if not bestZone then return nil end

    if getgenv().MaxTeleportZone > 0 then
        return math.min(bestZone, getgenv().MaxTeleportZone)
    end
    return bestZone
end

