                            for subK, subV in pairs(v) do
                                if type(subV) == "table" and subV.cost then
                                    subV.id = subV.id or subK
                                    table.insert(flatUpgrades, subV)
                                end
                            end
                        end
                    end
                end

                table.sort(flatUpgrades, function(a, b)
                    return (tonumber(a.cost.amount) or 0) < (tonumber(b.cost.amount) or 0)
                end)

                while getgenv().AutoBuyUpgrades do
                    local boughtSomething = false
                    pcall(function()
                        local owned = upgradesSrc() or {}
                        for _, upg in ipairs(flatUpgrades) do
                            if not getgenv().AutoBuyUpgrades then break end
                            if UpgradeCounterUtils.canPurchase(upg, owned, getCurrencyAmt) then
                                local success = UpgradeRemote:InvokeServer("requestUnlock", upg.id)
                                if success then
                                    boughtSomething = true
                                    task.wait(0.1)
                                    owned = upgradesSrc() or {}
                                end
                            end
                        end
                    end)
                    if boughtSomething then
                        task.wait(0.5)
                    else
                        task.wait(2.5)
                    end
                end
                pcall(destroyScope)
            end)
        end
    end,
})

