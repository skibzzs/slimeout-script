MainTab:CreateToggle({
    Name = "Auto Roll",
    CurrentValue = false,
    Flag = "AutoRoll_Flag",
    Callback = function(Value)
        getgenv().AutoRoll = Value
        if getgenv().AutoRoll then
            task.spawn(function()
                local vide = require(ReplicatedStorage.Packages.Vide)
                local getDataSource = require(ReplicatedStorage.Source.Core.UI.Sources.getDataSource)
                local statsSrc
                local destroyScope = vide.root(function()
                    statsSrc = getDataSource("stats")
                end)
                table.insert(getgenv().VideScopes, destroyScope)

                while getgenv().AutoRoll do
                    pcall(function()
                        local result = RollRemote:InvokeServer("requestRoll")

                        if type(result) == "table" and result[1] and result[1][1] then
                            local rollData = result[1][1]
                            local petId = rollData.id or "Unknown"
                            local activeMutations = rollData.mutations or {}

                            local slimeData = SlimesModule.getSlime(petId)
                            local baseOdds = slimeData and slimeData.rollOdds or 1
                            local oddsMultiplier = MutationsModule.getVisualOddsMultiplier(activeMutations)

                            local finalOdds = 1
                            if baseOdds < 1 then
                                finalOdds = (1 / baseOdds) * oddsMultiplier
                            else
                                finalOdds = baseOdds * oddsMultiplier
                            end

                            local isMutated = MutationsModule.hasAny(activeMutations)
                            local mutationsStr = "None"

                            if isMutated then
                                local mutNames = {}
                                for _, mutId in ipairs(MutationsModule.getIds(activeMutations)) do
                                    table.insert(mutNames, MutationsModule.get(mutId).name)
                                end
                                mutationsStr = table.concat(mutNames, ", ")
                            end

                            local displayOdds = formatOdds(1 / finalOdds)
                            local baseName = slimeData and slimeData.name or petId
                            local fullName = MutationsModule.getDisplayName(baseName, activeMutations)

                            local targetImageId = slimeData and slimeData.image or nil
                            if MutationsModule.has(activeMutations, "inverted") then
                                if slimeData and slimeData.invertedIcon then
                                    targetImageId = slimeData.invertedIcon
                                end
                            end

                            local backupImageId = slimeData and slimeData.image or nil

                            if finalOdds >= getgenv().MinThreshold then
                                local rollCount = 0
                                if statsSrc then
                                    local statsTbl = statsSrc()
                                    rollCount = safeRead(statsTbl, "rolls", 0)
                                end

                                table.insert(WebhookQueue, {
                                    sendFunc = function()
                                        sendRollWebhook(fullName, baseName, displayOdds, mutationsStr, targetImageId, backupImageId, rollCount)
                                    end
                                })
                            end
                        end
                    end)
                    task.wait(getgenv().AutoRollDelay)
                end

                pcall(destroyScope)
            end)
        end
    end,
})

