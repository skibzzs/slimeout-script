-- ==============================================

local function sendRollWebhook(fullName, baseName, displayOdds, mutationsStr, imageId, backupImageId, rollNumber)
    if getgenv().WebhookURL == "" then return end

    local contentStr = ""
    if getgenv().PingID ~= "" and getgenv().PingID ~= "nobody" then
        if getgenv().PingID:lower() == "everyone" then
            contentStr = "@everyone"
        else
            contentStr = "<@" .. getgenv().PingID .. ">"
        end
    end

    local titlePrefix = ""
    local titleSuffix = ""
    local isMutated = mutationsStr ~= "None"

    if isMutated then
        local mutLower = mutationsStr:lower()
        if string.find(mutLower, "inverted") then 
            titlePrefix = titlePrefix .. "🌌 "
            titleSuffix = " 🌌" .. titleSuffix 
        end
        if string.find(mutLower, "shiny") then 
            titlePrefix = titlePrefix .. "✨ "
            titleSuffix = " ✨" .. titleSuffix 
        end
        if string.find(mutLower, "huge") then 
            titlePrefix = titlePrefix .. "🐘 "
            titleSuffix = " 🐘" .. titleSuffix 
        end
        if string.find(mutLower, "big") then 
            titlePrefix = titlePrefix .. "🦍 "
            titleSuffix = " 🦍" .. titleSuffix 
        end
    end

    local titleMsg = "**" .. titlePrefix .. string.upper(fullName) .. titleSuffix .. "**"
    local playerStr = getgenv().ShowUsername and ("||" .. LocalPlayer.Name .. "||") or "Hidden"
    local rollStr = formatNumberSuffix(rollNumber)

    local embed = {
        ["title"] = getgenv().EmbedTitle,
        ["description"] = "You just rolled a " .. titleMsg .. "!\n👤 **Player:** " .. playerStr,
        ["color"] = isMutated and 16763904 or 15105570,
        ["fields"] = {
            { ["name"] = "Slime", ["value"] = baseName, ["inline"] = true },
            { ["name"] = "Chance", ["value"] = displayOdds, ["inline"] = true },
            { ["name"] = "Mutations", ["value"] = mutationsStr, ["inline"] = true },
            { ["name"] = "Rolled At", ["value"] = rollStr .. " Rolls", ["inline"] = true }
        },
        ["footer"] = { ["text"] = "Auto Roll Logger" }
    }

    local imgUrl = getRobloxImage(imageId)
    if not imgUrl and backupImageId then
        imgUrl = getRobloxImage(backupImageId)
    end

    if imgUrl then
        embed["thumbnail"] = { ["url"] = imgUrl }
    end

    local data = {
        ["content"] = contentStr,
        ["embeds"] = {embed}
    }

    local reqFunc = (request or http and http.request or syn and syn.request)
    if reqFunc then
        local response = reqFunc({
            Url = getgenv().WebhookURL,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(data)
        })

        if response and response.StatusCode == 400 and embed["thumbnail"] then
            embed["thumbnail"] = nil
            data.embeds = {embed}
            reqFunc({
                Url = getgenv().WebhookURL,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = HttpService:JSONEncode(data)
            })
        end
    end
end

