local function teleportToZoneCenter(targetZoneId)
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local root = char:FindFirstChild("HumanoidRootPart")

    if root then
        -- First fire the server remote so the game thinks we belong there (prevents anti-cheat checks)
        pcall(function() ZonesServiceClient:teleportToZone(targetZoneId) end)

        -- If Center Teleport is enabled, override the position smoothly after the game loads the zone
        if getgenv().CenterTeleport then
            task.wait(0.75) -- Give the game time to finish its own teleport so it doesn't overwrite ours

            local zoneFolder = workspace:FindFirstChild("Zones")
            if zoneFolder then
                local specificZone = zoneFolder:FindFirstChild(tostring(targetZoneId))
                if specificZone then
                    local targetPos = nil

                    local function getSpatialCenter(folderOrModel)
                        if not folderOrModel then return nil end

                        -- If it's a Model, Roblox has a built-in function to get the exact center of its bounding box
                        if folderOrModel:IsA("Model") then
                            local cframe, size = folderOrModel:GetBoundingBox()
                            return cframe.Position
                        end

                        -- If it's a folder, mathematically calculate the center of all parts inside
                        local minX, minY, minZ = math.huge, math.huge, math.huge
                        local maxX, maxY, maxZ = -math.huge, -math.huge, -math.huge
                        local foundParts = false

                        for _, v in ipairs(folderOrModel:GetDescendants()) do
                            if v:IsA("BasePart") then
                                foundParts = true
                                minX = math.min(minX, v.Position.X)
                                minY = math.min(minY, v.Position.Y)
                                minZ = math.min(minZ, v.Position.Z)
                                maxX = math.max(maxX, v.Position.X)
                                maxY = math.max(maxY, v.Position.Y)
                                maxZ = math.max(maxZ, v.Position.Z)
                            end
                        end

                        if foundParts then
                            return Vector3.new((minX + maxX) / 2, (minY + maxY) / 2, (minZ + maxZ) / 2)
                        end
                        return nil
                    end

                    targetPos = getSpatialCenter(specificZone:FindFirstChild("POI"))
                    if not targetPos then
                        targetPos = getSpatialCenter(specificZone:FindFirstChild("decor"))
                    end
                    if not targetPos then
                        targetPos = getSpatialCenter(specificZone) -- Final fallback to the whole zone
                    end

                    if targetPos then
                        -- Tween them to the center to avoid getting stuck in blocks
                        local tween = TweenService:Create(root, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                            CFrame = CFrame.new(targetPos.X, targetPos.Y + 10, targetPos.Z)
                        })
                        tween:Play()
                    end
                end
            end
        elseif getgenv().TeleportMode == "Custom" and getgenv().CustomPos then
            task.wait(0.75)
            local customPos = getgenv().CustomPos
            local tween = TweenService:Create(root, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
                CFrame = CFrame.new(customPos.X, customPos.Y, customPos.Z)
            })
            tween:Play()
        end
    end
end

local function startContinuousTeleport()
    if isAutoTpRunning then return end
    isAutoTpRunning = true

    task.spawn(function()
        while getgenv().AutoTpZones do
            pcall(function()
                local targetZone = getTargetZone()
                local currentZone = ZonesServiceClient:getZone()

                if targetZone and currentZone and currentZone ~= targetZone then
                    teleportToZoneCenter(targetZone)
                end
            end)
            task.wait(5)
        end
        isAutoTpRunning = false
    end)
end

